# DataWhisperer Environment Variables
# Copy this file to ".env" and fill in your actual key. Never commit ".env" to Git.

# Google Gemini API key (preferred LLM)
# Get one free at https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=your_google_gemini_api_key_here

# Optional: OpenAI fallback (only needed if you switch LLM_PROVIDER=openai)
OPENAI_API_KEY=your_openai_api_key_here

# Optional: xAI Grok key (only needed if you switch LLM_PROVIDER=grok)
# Get one at https://console.x.ai
# Note: xAI requires you to add credits/billing to your team before the API will work.
GROK_API_KEY=your_grok_api_key_here

# Optional: Groq key (only needed if you switch LLM_PROVIDER=groq)
# Get one free (no card needed) at https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# Which provider to use: "gemini", "openai", "grok", or "groq"
LLM_PROVIDER=groq

# Gemini model name
GEMINI_MODEL=gemini-1.5-flash

# OpenAI model name (used only if LLM_PROVIDER=openai)
OPENAI_MODEL=gpt-4o-mini

# Grok model name (used only if LLM_PROVIDER=grok)
GROK_MODEL=grok-4.3

# Groq model name (used only if LLM_PROVIDER=groq)
GROQ_MODEL=llama-3.3-70b-versatile
